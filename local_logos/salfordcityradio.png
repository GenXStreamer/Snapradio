        	<!-- BREAKING NEWS BAR -->
<div id="breakingNews" class="breaking-news-bar">
  <span class="bn-label">LIVE NEWS</span>

  <a class="bn-link"
     href="https://www.salfordcityradio.com/news/local-news/reform-candidate-elected-in-salford-as-party-wins-first-council-seat-in-city"
     target="_self">
     Reform UK win first seat on Salford City Council in by-election - read more
  </a>
</div>

<style>
  .breaking-news-bar{
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 99999;

    display: flex;
    align-items: center;
    gap: 14px;

    background: #c40000;
    color: #ffffff;

    padding: 12px 18px;
    min-height: 52px;

    font-family: Arial, Helvetica, sans-serif;
    box-shadow: 0 -4px 14px rgba(0,0,0,0.25);
  }

  .bn-label{
    font-weight: 900;
    letter-spacing: 0.1em;
    font-size: 15px;
    text-transform: uppercase;

    background: rgba(0,0,0,0.3);
    padding: 6px 12px;
    border-radius: 5px;
    white-space: nowrap;
  }

  .bn-link{
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    font-size: 15px;
    transition: color 0.2s ease;
  }

  .bn-link:hover{
    color: #ffd200;
  }

  @media (max-width: 520px){
    .breaking-news-bar{
      padding: 10px 14px;
      min-height: 48px;
    }
    .bn-link{
      font-size: 14px;
    }
  }
</style>

<script>
  /* ===============================
     BREAKING NEWS MASTER SWITCH
     true  = ON
     false = OFF
     =============================== */
  const BREAKING_NEWS_ENABLED = false;

  document.addEventListener("DOMContentLoaded", function () {

    const bar = document.getElementById("breakingNews");
    if (!bar) return;

    // Hard disable when switched off
    if (!BREAKING_NEWS_ENABLED) {
      bar.style.display = "none";
      return;
    }

    // Get article path from the link itself
    const link = bar.querySelector("a");
    if (!link) return;

    const linkPath = new URL(link.href).pathname;
    const currentPath = window.location.pathname;

    // Hide bar if user is already on the article page
    if (currentPath === linkPath) {
      bar.style.display = "none";
    }

  });
</script>
