    .mob-only{
        display: none;
      }
      @media (max-width: 992px) {
        .mob-only{
      display: block !important;
      }
</style><div class="mob-only row">
<div class="com-12 text-center">
  
  <button
  id="audioButton1"
  class=" mt-3 css" 
>

<img decoding="async" src="https://sanskarradio.com/wip/wp-content/uploads/2025/11/play-1.gif" id="play1" >
<img decoding="async" src="https://sanskarradio.com/wip/wp-content/uploads/2025/11/pause-1.gif" id="pause1" style="display: none;"> 
 </button>
<audio
id="liveAudio1"
src="https://radio.canstream.co.uk:8024/live.mp3"
preload="none"
></audio>
<script>
  const audioButton1 = document.getElementById('audioButton1');
  const liveAudio1 = document.getElementById('liveAudio1');
  const playImg1 = document.getElementById('play1');
  const pauseImg1 = document.getElementById('pause1');

