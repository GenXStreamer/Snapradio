						<div class="elementor-element elementor-element-0a4a043 elementor-widget-mobile__width-inherit elementor-widget elementor-widget-html" data-id="0a4a043" data-element_type="widget" data-e-type="widget" data-widget_type="html.default">
				<div class="elementor-widget-container">
					 
  
 
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Live Audio Player</title>
  <!-- Link to Font Awesome for font icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  
  <style>
   button{
       background-color: transparent !important;
       border: 0px !important
   }
   
  </style>
</head>
<body> 
 <div  class="header-btn">
     
     
     
       <button 
            id="audioButton"
            class=" mt-3 desk-only head-btn"
            style=" margin-top: 0px !important; text-align: left; padding: 0px;"
          >
          <img src="https://sanskarradio.com/wip/wp-content/uploads/2025/11/play-1.gif" id="play" >
                      <img src="https://sanskarradio.com/wip/wp-content/uploads/2025/11/pause-1.gif" id="pause" style="display: none;">
            <!-- <i class="fas fa-play"></i> <span id="buttonText">Play</span> -->
          </button>
          
          
          <a class=" head-btn" href="https://podcast.canstream.co.uk/sanskar/" target="_blank" class="desk-only" >  <img src="https://sanskarradio.com/wip/wp-content/uploads/2025/11/listenagain.gif"  ></a>
          
       
           
        <a class=" head-btn" href="https://wa.me/+447979389599" class="desk-only" target="_blank" > <img src="https://sanskarradio.com/wip/wp-content/uploads/2025/11/whatsapp.png" ></a>
        </div>
         
         
         
         
  <audio
  id="liveAudio"
  src="https://radio.canstream.co.uk:8024/live.mp3"
  preload="none"
></audio>
<script>
    const audioButton = document.getElementById('audioButton');
    const liveAudio = document.getElementById('liveAudio');
    const playImg = document.getElementById('play');
    const pauseImg = document.getElementById('pause');
  
    audioButton.addEventListener('click', () => {
      if (liveAudio.paused) {
        liveAudio.play();
        playImg.style.display = 'none';
        pauseImg.style.display = 'inline';
      } else {
        liveAudio.pause();
        playImg.style.display = 'inline';
        pauseImg.style.display = 'none';
      }
    });
  
    // Optional: when audio ends, revert to play icon
    liveAudio.addEventListener('ended', () => {
      playImg.style.display = 'inline';
      pauseImg.style.display = 'none';
    });
  </script>
         
</body> 
</html>
				</div>
