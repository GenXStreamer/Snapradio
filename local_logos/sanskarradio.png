						<div class="elementor-element elementor-element-d4220ed elementor-widget__width-inherit elementor-widget elementor-widget-html" data-id="d4220ed" data-element_type="widget" data-e-type="widget" data-widget_type="html.default">
				<div class="elementor-widget-container">
					<!DOCTYPE html>
<html lang="en">
<head>
  <title>Bootstrap Carousel</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <style>
    .cust h1 { color: #fff; font-size: 400%; }
    .cust p { color: rgba(255,255,255,0.6); font-size: 18px; margin-bottom: 30px; }

    .slide-content {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 90vh;
      text-align: left;
    }

    .btn.btn-primary {
      background-color: #fa9512 !important;
      border: 1px solid #fa9512 !important;
      color: #fff !important;
      padding: 10px 30px;
      transition: 0.5s;
    }

    .btn.btn-primary:hover {
      background-color: transparent !important;
      color: #fa9512 !important;
      box-shadow: 0px 0px 10px #fa9512;
    }

    .cust .carousel-control-prev,
    .cust .carousel-control-next {
      width: 3%;
    }

    @media (max-width: 768px) {
      .cust h1 { font-size: 200%; }
      .slide-content { text-align: center; }
    }
  </style>
</head>

<body>

<div id="demo"
     class="cust carousel slide"
     data-bs-ride="carousel"
     data-bs-wrap="true"
     data-bs-interval="5000">

  <!-- Indicators -->
  <div class="carousel-indicators">
    <button type="button" data-bs-target="#demo" data-bs-slide-to="0" class="active"></button>
    <button type="button" data-bs-target="#demo" data-bs-slide-to="1"></button>
    <button type="button" data-bs-target="#demo" data-bs-slide-to="2"></button>
    <button type="button" data-bs-target="#demo" data-bs-slide-to="3"></button>
  </div>

  <!-- Slides -->
  <div class="carousel-inner">

    <!-- Slide 1 -->
    <div class="carousel-item active" style="background:url('https://sanskarradio.com/wip/wp-content/uploads/2025/11/banner-1.png') center/cover no-repeat; height:90vh;">
      <div class="row h-100">
        <div class="col-md-6"></div>
        <div class="col-md-6 col-12 slide-content">
          <div>
            <h1>Sanskar Radio</h1>
            <p>Serving worldwide here today and tomorrow</p>
            <a href="#" class="btn btn-primary">Know More</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 2 -->
    <div class="carousel-item" style="background:url('https://sanskarradio.com/wip/wp-content/uploads/2025/11/banner-2.png') center/cover no-repeat; height:90vh;">
      <div class="row h-100">
        <div class="col-md-6"></div>
        <div class="col-md-6 col-12 slide-content">
          <div>
            <h1>Sanskar Radio</h1>
            <p>Have the cultural show host appear briefly on other programs.</p>
            <a href="#" class="btn btn-primary">Know More</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 3 -->
    <div class="carousel-item" style="background:url('https://sanskarradio.com/wip/wp-content/uploads/2026/05/banner-7.png') center/cover no-repeat; height:90vh;">
      <div class="row h-100">
        <div class="col-md-3"></div>
        <div class="col-md-6 col-12 slide-content text-center">
          <div>
            <h1>Purshootam Mass Shubhkamana</h1>
            <p>, May this holy month fill your life with happiness, health, peace, and spiritual growth.
              Have a great month ahead!</p>
            <a href="#" class="btn btn-primary">Know More</a>
          </div>
        </div>
        <div class="col-md-3"></div>
      </div>
    </div>

     <!-- Slide 4 -->
     <div class="carousel-item" style="background:url('https://sanskarradio.com/wip/wp-content/uploads/2026/05/banner-6.png') center/cover no-repeat; height:90vh;">
      <div class="row h-100">
        <div class="col-md-6"></div>
        <div class="col-md-6 col-12 slide-content">
          <div>
            <h1>Keep Faith</h1>
            <p>Support Sanskar Radio in sharing devotion, values, and harmony daily.</p>
            <a href="#donate" class="btn btn-primary">Donat Us</a>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Controls -->
  <button class="carousel-control-prev" type="button" data-bs-target="#demo" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#demo" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

</div>

</body>
</html>
				</div>
				</div>
				<div class="elementor-element elementor-element-f594c86 elementor-widget elementor-widget-html" data-id="f594c86" data-element_type="widget" data-e-type="widget" data-widget_type="html.default">
				<div class="elementor-widget-container">
					<!DOCTYPE html>
<html lang="en">
<head>
  <title>Bootstrap Example</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <style>
    .live-section{
      width: 500px;
      min-height: 130px;
      height: auto;
      background-color: #f2f2f2;
      position: absolute;
      bottom: 100px;
      left: 100px;
      padding: 15px;
      display: flex;
      display: none
    }
    .photo-section{
      background-color: #ccc;
      width: 150px; 
      min-height: 130px;
      height: auto;
      float: left;
    }
    .info-section{
      background-color: #fff;
      width: calc(100% - 150px);
      min-height: 130px;
      height: auto;
      float: left;
      padding: 10px;
    }
    .info-section p{
      margin-bottom: 0px;
    }
    
    .info-section h3{
      margin-bottom: 0px;
    }
    .timing{
      font-size: 80%;
      color: #999;
    }
      @media only screen and (max-width: 600px)
{
.live-section {
    width: 100%;
    min-height: 130px;
    height: auto;
    background-color: #f2f2f2;
    position: absolute;
    bottom: -150px;
    left: 0px;
    padding: 15px;
    z-index: 9;
    display: flex;
     display: none
;

}
  </style>
</head>
<body >

<!-- Carousel -->
<div class="live-section"  >
  <div class="photo-section">
      &nbsp;
  </div>
  <div class="info-section">
   <p>On Air</p>
   <h3>Sushma Thakkar </h3>
   <p>Spiritural Bhakti Sangeet</p>
   
   <p class="timing">3:00PM - 7:00PM </p>
</div>

   
</div>
 
</body>
</html>
