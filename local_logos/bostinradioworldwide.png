15f49b6c87127919d0cafafcadb76f6f4e57737b7348\/2021-08-25_00-09-15_1629846572.jpg?width=400","800w":"\/uploads\/b\/bd06623bbccb257f5e8915f49b6c87127919d0cafafcadb76f6f4e57737b7348\/2021-08-25_00-09-15_1629846572.jpg?width=800","1200w":"\/uploads\/b\/bd06623bbccb257f5e8915f49b6c87127919d0cafafcadb76f6f4e57737b7348\/2021-08-25_00-09-15_1629846572.jpg?width=1200","1600w":"\/uploads\/b\/bd06623bbccb257f5e8915f49b6c87127919d0cafafcadb76f6f4e57737b7348\/2021-08-25_00-09-15_1629846572.jpg?width=1600","2000w":"\/uploads\/b\/bd06623bbccb257f5e8915f49b6c87127919d0cafafcadb76f6f4e57737b7348\/2021-08-25_00-09-15_1629846572.jpg?width=2000","2400w":"\/uploads\/b\/bd06623bbccb257f5e8915f49b6c87127919d0cafafcadb76f6f4e57737b7348\/2021-08-25_00-09-15_1629846572.jpg?width=2400"},"focalPoint":{"x":0.5,"y":0.5},"attribution":{},"cropOptions":{"zoom":1,"center":{"x":0.5,"y":0.5},"realZoom":1,"rotation":0},"positionPoint":{"x":0.5,"y":0.5},"overlayOpacity":0.12}},"hoverEffect":"text","lastRefetch":1629846322832,"colorProfile":"primary-light-bold","sectionTitle":{"color":"var(--gray-light-one)","title":{"quill":{"ops":[{"insert":"Featured categories"},{"insert":"\n","attributes":{"block":true}}]}},"hidden":false,"fontFamily":"--primary-font"},"categoryLinks":{},"overlayTitles":{"color":"--color-white","fontSize":"step-3","fontFamily":"--secondary-font"},"sectionSubtitle":{"color":"var(--primary-bright-light)","hidden":false,"content":{"quill":{"ops":[{"insert":"Our latest collections are full of items you will love"},{"insert":"\n","attributes":{"block":true}}]}},"fontSize":"step-1","textStyle":"title","fontFamily":"--primary-font"},"selectedCategories":[2,3]}}}]}}}}}},"storeInfo":{"merchant_id":"ML2W7QXD5YEZ8","buyer_customer_accounts_enabled":false,"currency":"GBP","locale":"en_GB","language":"en","syncing_disabled":true,"return_policy":"<p><strong>As indicated in our Shipping Policy, we inspect all goods before dispatch and we do our best to supply quality innovative and unique products and services. <u>e-Tickets or physical tickets are dispatched by email or by post (<\/u><em><u>* See T&amp;C's regarding tickets in 4th paragraph below<\/u><\/em><u>).<\/u><\/strong><\/p><p><br><\/p><p>All Goods are of the best Quality possible and where fabrics are concerned, Please ensure you read all enclosed washing, storage or maintenance instructions. Where Goods are damaged on receipt or are of the wrong size, as long as not used we will accept returns within 5 working days of receipt. Failure to read instruction or utilize product appropriately will render any returns or refunds void.<\/p><p><br><\/p><p>Where goods are not delivered, damaged or not fit for purpose as described, on return of the goods in appropriate packaging, we will inspect them and if damaged or wrong size etc., then we will give a full refund or replacement. But where there is obvious sign of use or wear an tear, we will offer a partial or full refund in the form of a Voucher to the amount as appropriate.<\/p><p><br><\/p><p>Again with Tech or Gifts (excluding Clothing and Baseball Caps or scarfs) if the same is not as ordered, e.g. mis-spelling on bespoke branding or it doesn't work, we will offer Discount Voucher, Good Will Voucher or a full refund up to 30 days from time of purchase. Beyond 30 days, no refunds will be considered or given (Tech Items and Gift Ideas only, Bespoke Clothing is as 1st paragraph).<\/p><p><br><\/p><p><strong>None of the Above applies to Service and Subscription Services such as Membership Club, Ticketing and Podcast Services* (* Tickets are non transferable, but full refunds minus booking fees will be refunded in the event of the cancellation of a ticketed event)<\/strong><\/p><p><br><\/p><p><strong>Donations, Subscription &amp; Membership Fees are non negotiable and by their nature as they are all rolling contracts and cancellation at the end of any month or quarter allowed, no returns or refunds are applicable. Your Rights as a consumer are not affected where delivery of certain services have not been met or the APP we sell\/ distribute elsewhere via Google Play and iOS APP Store are all governed by separate terms and conditions governed by the platforms that customers download them from.<\/strong><\/p>","shipping_policy":"<p><strong>The Majority of Goods ordered are shipped by Royal Mail Post, Bulk Orders by Courier or Special Delivery and where stipulated and usually take between 3-7 working days within the UK, Europe, 7 days, Rest of the World must allow up to 14 days (but we usually aim for 10, most prices include postage &amp; packaging, unless otherwise stated). Prices too can change from time to time within at any time and this may include special offers, sometimes monthly, but mostly quarterly.<\/strong><\/p><p><br><\/p><p><em>All queries and updates on orders must be made by email outlined on our websites &amp;\/or via enquiry boxes and we endeavor to respond to general enquiries within 24 hrs.<\/em><\/p><p><br><\/p><p><strong>Every Order is confirmed with a receipt and shipped online. We will ship the majority of the time by 1st or 2nd class post or deliver where needed and viable we will do 'Local Delivery' within 8 miles of Birmingham UK or 8 Miles of Kington, otherwise 99.9% of Digital Services are delivered online and physical products by 2nd Class Post, 1st Class if orders in excess of \u00a350 or Courier (Value Dependent). e-Tickets by email or SMS.<\/strong><\/p><p><br><\/p><p><em>All Goods are of the best Quality possible and where fabrics are concerned we inspect rigorously before Shipping to Customers\/Clients, <\/em><\/p><p><br><\/p><p><strong>None of the Above applies to Service and Subscription Services such as Membership Club and Podcast Services*<\/strong><\/p><p><br><\/p><p><strong>Every Order in such cases are confirmed with a receipt and shipped online. Where Physical added benefits are involved, we will ship by post or deliver where within 8 miles of Birmingham UK or 8 Miles of Kington, where possible, otherwise 99.9% of Digital Services are delivered online and physical products by Post or Courier.<\/strong><\/p><p><br><\/p><p><strong>Donations, Subscription &amp; Membership Fees are non negotiable and by their nature as they are all rolling contracts and cancellation at the end of any month or quarter allowed, no returns or refunds are applicable. Your Rights as a consumer are not affected where delivery of certain services have not been met or the APP we sell\/ distribute elsewhere via Google Play and iOS APP Store are all governed by separate terms and conditions governed by the platforms that customers download them from.<\/strong><\/p><p><br><\/p><p><strong>All Logos, Branded Designs and Services<\/strong> are the bona fide Intellectual property of <strong>Funky Apple Design &amp; Biz Hub t\/as <a href=\"https:\/\/bostinradio.com\/\" rel=\"noopener noreferrer\" target=\"_blank\">Bostin Radio Worldwide<\/a> &amp; BostinRadioShopping online<\/strong>. For more info on us and the Radio Station, our <strong><a href=\"https:\/\/bostinradio.com\/privacypolicy.html\" rel=\"noopener noreferrer\" target=\"_blank\">Privacy Policies<\/a><\/strong> and more go to our Live online 24\/7 <a href=\"https:\/\/bostinradio.com\/privacypolicy.html\" rel=\"noopener noreferrer\" target=\"_blank\">WEBSITE*<\/a><\/p>","max_donation_amount":4000,"store_mode":"cart","payment_method_support":{"visa":true,"mastercard":true,"amex":true,"discover":false,"jcb":false,"interac":false,"paypal":false,"apple_pay":true,"google_pay":true,"cash_app":false,"square_pay":true},"show_pdp_buy_now_button":true,"allowed_to_sell":true,"accepting_orders":true,"has_payment_processor":true,"is_group_ordering_enabled":false,"product_reviews_enabled":false,"show_on_sale_section":true,"show_low_stock_section":false,"show_out_of_stock_section":true,"shipping_location_ids":["LCDC2DBG2WKFZ"],"fulfillment_support":{"delivery":false,"pickup":false,"shipping":true,"dine_in":false,"manual":false,"digita