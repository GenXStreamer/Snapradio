[Unit]
Description=DAB Radio Studio (Snapradio)
After=network.target pipewire.service pipewire-pulse.service

[Service]
Type=simple
WorkingDirectory=/opt/Snapradio
Environment="PATH=%h/venv/bin:/usr/bin:/usr/local/bin"
ExecStart=%h/venv/bin/python main.py
ExecStop=/bin/kill -TERM $MAINPID
KillMode=control-group
KillSignal=SIGTERM
TimeoutStopSec=10
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
